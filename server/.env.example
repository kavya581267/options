PORT=3001
DATA_DIR=./data
SYMBOLS=NIFTY,SENSEX
MARKET_START=09:15
MARKET_END=15:30
TIMEZONE=Asia/Kolkata
# Set to true to run fetcher outside market hours (for testing)
FORCE_FETCH=false
# BSE scrip code for SENSEX index (default 1)
SENSEX_SCRIPCODE=1

# --- Kotak Neo API v2 (separate /kotak page) ---
KOTAK_ACCESS_TOKEN=
KOTAK_MOBILE_NUMBER=+91XXXXXXXXXX
KOTAK_UCC=
TRADING_SYMBOL=NIFTY
TRADING_SIDE=SELL
TRADING_LOTS=1
TRADING_PRODUCT=MIS
TRADING_USE_BO=false
SL_TYPE=percent
SL_VALUE=20
TARGET_TYPE=percent
TARGET_VALUE=30

# --- Fyers API v3 (separate /fyers page) ---
# App id / secret (either naming works):
FYERS_APP_ID=
FYERS_SECRET_KEY=
# Or: FYERS_API_KEY=...  FYERS_API_SECRET=...
# Must match redirect URL in Fyers app dashboard exactly:
FYERS_REDIRECT_URI=http://127.0.0.1:5173/
FYERS_TRADING_SYMBOL=NIFTY
FYERS_TRADING_SIDE=SELL
FYERS_TRADING_LOTS=1
FYERS_TRADING_PRODUCT=MIS
FYERS_SL_TYPE=percent
FYERS_SL_VALUE=20
FYERS_TARGET_TYPE=percent
FYERS_TARGET_VALUE=30

# --- Stock screener (/screener page) ---
# Universe: all | nse_equity | bse_equity
SCREENER_UNIVERSE=all
# Delay between symbols during scan (ms) — mostly cache reads
SCREENER_DELAY_MS=50
# Auto-run daily scan after market close (IST, Mon–Fri)
SCREENER_AUTO_RUN=true
SCREENER_AUTO_RUN_TIME=16:00
